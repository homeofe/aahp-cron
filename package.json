{
  "name": "aahp-cron",
  "version": "0.1.2",
  "description": "Pipeline orchestrator for AAHP v3 - schedules and runs aahp-runner across all projects",
  "license": "Apache-2.0",
  "author": "Elvatis <emre.kohler@elvatis.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/homeofe/aahp-cron.git"
  },
  "keywords": [
    "aahp",
    "cron",
    "pipeline",
    "orchestrator",
    "agent",
    "autonomous",
    "claude",
    "scheduler"
  ],
  "type": "module",
  "bin": {
    "aahp-cron": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p ./",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
